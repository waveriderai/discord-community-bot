# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Claude AI Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Bot Settings
BOT_PREFIX=!
BOT_NAME=WaveRider Bot

# Channels (Discord Channel IDs)
CHANNEL_BOT_QA=
CHANNEL_ANNOUNCEMENTS=

# Internal Services Integration
# Prometheus (for /status command)
PROMETHEUS_URL=http://prometheus:9090

# AlertManager (for /alerts command)
ALERTMANAGER_URL=http://alertmanager:9093

# Plane.so (for /tasks command)
PLANE_URL=https://lineup.waverider.ai
PLANE_API_KEY=your_plane_api_key_here
PLANE_WORKSPACE=waverider

# Outline Wiki (for /search command)
OUTLINE_URL=https://shack.waverider.ai
OUTLINE_API_KEY=your_outline_api_key_here

# Discord Webhooks — Market Pulse
DISCORD_WEBHOOK_MARKET_PULSE=

# Discord Webhooks — Strategy Alerts (Public)
DISCORD_WEBHOOK_CONTINUATION=
DISCORD_WEBHOOK_REVERSAL=
DISCORD_WEBHOOK_9M_CATALYST=
DISCORD_WEBHOOK_STOCKS_IN_PLAY=
DISCORD_WEBHOOK_EARNINGS=

# Discord Webhooks — Strategy Alerts (Rider+)
DISCORD_WEBHOOK_RIDER_CONTINUATION=
DISCORD_WEBHOOK_RIDER_REVERSAL=
DISCORD_WEBHOOK_RIDER_9M_CATALYST=
DISCORD_WEBHOOK_RIDER_SIP=
DISCORD_WEBHOOK_RIDER_EARNINGS=

# Discord Webhooks — Sell Alerts
DISCORD_WEBHOOK_SELL_ALERTS=

# Discord Webhooks — Content
DISCORD_WEBHOOK_ANALYSIS=
DISCORD_WEBHOOK_PODCAST=

# Discord Webhooks — Pro
DISCORD_WEBHOOK_PRO_FULL_SCAN=
DISCORD_WEBHOOK_PRO_INSTITUTIONAL=

# Discord Webhooks — Announcements
DISCORD_WEBHOOK_ANNOUNCEMENTS=

# Logging
LOG_LEVEL=INFO
